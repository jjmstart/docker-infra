services:
  nginx:
    image: nginx:1.27-alpine
    container_name: nginx
    restart: unless-stopped

    ports:
      - "80:80"
      - "8443:443"

    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./conf.d:/etc/nginx/conf.d:ro
      - ./ssl:/etc/nginx/ssl:ro
      - ./html:/var/www/html:ro
      - ./ruoyi-ui-dist:/usr/share/nginx/ruoyi:ro

    healthcheck:
      test: ["CMD-SHELL", "wget -q --no-check-certificate -O /dev/null https://127.0.0.1/ || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

    mem_reservation: 32m

    deploy:
      resources:
        limits:
          memory: 128m
