bind 0.0.0.0
protected-mode no
port {{ redis_port }}

replica-announce-ip {{ ansible_host }}
replica-announce-port {{ redis_port }}

replicaof {{ redis_master_host }} {{ redis_port }}
replica-priority {{ redis_replica_priority }}

maxmemory {{ redis_maxmemory }}
maxmemory-policy allkeys-lru

appendonly yes
appendfsync everysec
aof-use-rdb-preamble yes
