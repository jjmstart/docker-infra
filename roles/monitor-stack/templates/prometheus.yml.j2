global:
  scrape_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - '{{ alertmanager_host }}:{{ alertmanager_port }}'

rule_files:
  - "rules/*.yml"

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node-exporter'
    static_configs:
      - targets:
{% for host in groups['exporter_nodes'] %}
          - '{{ hostvars[host].ansible_host }}:{{ node_exporter_port }}'
{% endfor %}

  - job_name: 'mysqld-exporter'
    static_configs:
      - targets: ['{{ mysql_master_host }}:{{ mysqld_exporter_port }}']
        labels:
          instance: 'gz-03'
          role: 'master'
      - targets: ['{{ mysql_replica_realtime_host }}:{{ mysqld_exporter_port }}']
        labels:
          instance: 'gz-02'
          role: 'slave1'
      - targets: ['{{ mysql_replica_delay_host }}:{{ mysqld_exporter_port }}']
        labels:
          instance: 'bj-01'
          role: 'slave2'

  - job_name: 'blackbox-http'
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:

      - targets:
          - https://ruoyi.jjmstart.com
        labels:
          service: ruoyi
          severity: critical

      - targets:
          - https://diary.jjmstart.com
        labels:
          service: diary
          severity: warning

      - targets:
          - https://jenkins.jjmstart.com
        labels:
          service: jenkins
          severity: warning

      - targets:
          - https://monitor.jjmstart.com
        labels:
          service: grafana
          severity: warning

      - targets:
          - http://{{ prometheus_host }}:{{prometheus_port}}/-/healthy
        labels:
          service: prometheus
          severity: critical

      - targets:
          - http://{{ alertmanager_host }}:{{ alertmanager_port }}/-/healthy
        labels:
          service: alertmanager
          severity: critical


    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:{{ blackbox_exporter_port }}