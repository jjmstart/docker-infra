groups:
  # 外部入口可用性告警：由 blackbox-exporter 主动访问公网/内网 HTTP 目标。
  - name: blackbox
    rules:
      # probe_success=0 表示探测失败；severity 来自 prometheus.yml 中每个 target 的标签。
      - alert: BlackboxProbeFailed
        expr: probe_success{job="blackbox-http"} == 0
        for: 2m
        labels:
          severity: "{{ '{{' }} $labels.severity {{ '}}' }}"
        annotations:
          summary: "入口探测失败"
          description: "{{ '{{' }} $labels.service {{ '}}' }} 探测目标 {{ '{{' }} $labels.instance {{ '}}' }} 连续 2 分钟不可用。"