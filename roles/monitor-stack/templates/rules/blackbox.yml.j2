groups:
  - name: blackbox
    rules:
      - alert: BlackboxProbeFailed
        expr: probe_success{job="blackbox-http"} == 0
        for: 2m
        labels:
          severity: "{{ '{{' }} $labels.severity {{ '}}' }}"
        annotations:
          summary: "入口探测失败"
          description: "{{ '{{' }} $labels.service {{ '}}' }} 探测目标 {{ '{{' }} $labels.instance {{ '}}' }} 连续 2 分钟不可用。"