global:
  resolve_timeout: 5m

route:
  receiver: feishu
  group_by: ['alertname', 'cluster', 'job', 'instance', 'severity']
  group_wait: {{ alert_group_wait }}
  group_interval: {{ alert_group_interval }}
  repeat_interval: {{ alert_repeat_interval }}

receivers:
  - name: feishu
    webhook_configs:
      # fsurl 必须 urlencode：飞书 webhook URL 含 ":" "/" 等保留字符，
      # 不编码会被 prometheus-alert 解析 query 时截断，导致告警静默丢失
      - url: "http://prometheus-alert:{{ prometheus_alert_port }}/prometheusalert?type=fs&tpl=prometheus-fs&fsurl={{ alerting_feishu_webhook_url | urlencode }}"
        send_resolved: true

inhibit_rules:
  - source_matchers:
      - alertname = "NodeDown"
    target_matchers:
      - alertname =~ "NodeExporterDown|NodeDiskSpaceLow|NodeInodeLow|NodeMemoryLow|NodeCPUHigh"
    equal: ['instance']