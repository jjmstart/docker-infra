datadir="/var/lib/proxysql"

admin_variables=
{
    admin_credentials="{{ proxysql_admin_user }}:{{ proxysql_admin_password }}"
    mysql_ifaces="0.0.0.0:6032"
}

mysql_variables=
{
    threads=4
    max_connections=2048
    default_query_delay=0
    default_query_timeout=36000000
    have_compress=true
    poll_timeout=2000
    interfaces="0.0.0.0:6033"
    default_schema="information_schema"
    stacksize=1048576
    server_version="8.0.45"
    connect_timeout_server=3000
    monitor_username="{{ proxysql_monitor_user }}"
    monitor_password="{{ proxysql_monitor_password }}"
    monitor_history=600000
    monitor_connect_interval=60000
    monitor_ping_interval=10000
    monitor_read_only_interval=1500
    monitor_read_only_timeout=500
    ping_interval_server_msec=120000
    ping_timeout_server=500
    commands_stats=true
    sessions_sort=true
    connect_retries_on_failure=10
}

mysql_servers=
(
    {
        address="mysql"
        port={{ mysql_port }}
        hostgroup_id=0
        status="ONLINE"
        weight=1
        max_connections=200
        comment="gz-03 MySQL Master"
    },
    {
        address="{{ mysql_replica_realtime_host }}"
        port={{ mysql_port }}
        hostgroup_id=1
        status="ONLINE"
        weight=1
        max_connections=200
        comment="gz-02 MySQL Slave1"
    }
)

mysql_users=
(
    {
        username="{{ ruoyi_datasource_username }}"
        password="{{ ruoyi_datasource_password }}"
        default_hostgroup=0
        transaction_persistent=1
        active=1
    }
)

mysql_query_rules=
(
    {
        rule_id=1
        active=1
        match_digest="^SELECT .* FOR UPDATE"
        destination_hostgroup=0
        apply=1
        comment="SELECT FOR UPDATE to writer"
    },
    {
        rule_id=2
        active=1
        match_digest="^SELECT"
        destination_hostgroup=1
        apply=1
        comment="SELECT to reader"
    }
)
