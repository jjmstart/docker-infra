# ========= 数据目录（绝对不进 Git）=========
backend/mysql/data/
backend/redis/data/
backend/proxysql/data/

# ========= 真实密码文件（不进 Git，只有 .env.example 进入）=========
**/.env

# ========= SQL 备份文件 =========
backend/mysql/*.sql
backend/mysql/*.sql.gz

# ========= SSL 证书 =========
nginx/certs/
**/*.pem
**/*.key

# ========= 系统文件 =========
.DS_Store
*.log
.cursorignore
monitor/mysqld-exporter.cnf

# Local secret staging for Ansible migration
secrets-staging/

bj-01-configs/
gz-01-configs/
gz-02-configs/

# ========= Obsidian 工作区配置 =========
Docs/.obsidian/

# ========= Ansible vault 密码文件 =========
vault/.vault-pass

# ========= 仓库根级私人材料目录（绝对不进 Git）=========
# 用于本地存放与项目运营无关的个人材料；具体内容因人而异，由各自维护者自行管理。
# leading / 表示根锚定，只匹配仓库根的 private/，不影响子目录中可能出现的同名目录。
/private/